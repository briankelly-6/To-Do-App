# Supabase project credentials.
# These two values are safe to expose in the browser bundle: the anon key only
# permits what Row-Level Security allows, and all task rows are owner-scoped.
#
# Copy this file to `.env.local` and fill in the values from your Supabase
# project dashboard: Project Settings -> API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
